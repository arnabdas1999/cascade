#!/bin/sh
# Maven Wrapper script for Linux/macOS
# Uses the wrapper jar to bootstrap the correct Maven version.

set -e

# Resolve script directory
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

WRAPPER_JAR="$SCRIPT_DIR/.mvn/wrapper/maven-wrapper.jar"
WRAPPER_PROPERTIES="$SCRIPT_DIR/.mvn/wrapper/maven-wrapper.properties"

# Determine JAVA_HOME
if [ -n "$JAVA_HOME" ] ; then
  JAVACMD="$JAVA_HOME/bin/java"
else
  JAVACMD="java"
fi

if [ ! -x "$JAVACMD" ] && ! command -v "$JAVACMD" > /dev/null 2>&1 ; then
  echo "Error: JAVA_HOME is not set and no 'java' found in PATH." >&2
  exit 1
fi

exec "$JAVACMD" \
  -classpath "$WRAPPER_JAR" \
  "-Dmaven.multiModuleProjectDirectory=$SCRIPT_DIR" \
  org.apache.maven.wrapper.MavenWrapperMain \
  "$@"
